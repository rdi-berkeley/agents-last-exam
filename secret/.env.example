# =============================================================================
# .env.example — copy to `.env` and fill in. `.env` is gitignored.
#
# The loader auto-reads `.env` next to the experiment yaml before parsing,
# so any `${env:VARNAME}` reference in the yaml resolves without you having
# to `export` first. Shell env wins — a one-off `export FOO=bar` always
# overrides this file.
#
# Format: KEY=value per line. `#` starts a line comment. Quotes around the
# value are stripped. Lines starting with `export ` are tolerated.
# =============================================================================

# ---- LLM API keys (only the ones you actually use) -------------------------
# Picked up by claude-code CLI + the ale_claw harness's litellm client.
# Inside docker / VM runtimes these are propagated transparently.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional — only needed if you re-enable ale_claw's `web_search` tool.
BRAVE_API_KEY=

# ---- GCP (only needed if provider.kind=gcloud) -----------------------------
# Reference these from your yaml with `${env:GCP_PROJECT}` etc.
GCP_PROJECT=
GCP_SA_KEY=secret/gcp_key.json
