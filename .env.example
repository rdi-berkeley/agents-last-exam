# =============================================================================
# ALE environment configuration — copy to .env, fill in, then `source .env`
# =============================================================================
#
# Setup:
#     cp .env.example .env       # gitignored
#     $EDITOR .env               # fill values
#     source .env                # load into current shell
#     uv run python -m ale run experiments/foo.yaml
#
# All values are read from the operator's shell at run time. None of these
# belong in experiment yaml — yaml is committed; secrets/paths aren't.
# =============================================================================


# ---------- LLM API keys (set at least ONE) ----------
# Used by both ale_claw (litellm in-process) and claude_code (CLI in VM).
# claude_code auto-detects: if ANTHROPIC_API_KEY is unset but OPENROUTER_API_KEY
# is set, the in-VM bash script remaps to ANTHROPIC_AUTH_TOKEN +
# ANTHROPIC_BASE_URL=https://openrouter.ai/api.

export OPENROUTER_API_KEY=sk-or-...
# export ANTHROPIC_API_KEY=sk-ant-...
# export OPENAI_API_KEY=sk-...
# export BRAVE_API_KEY=...                    # needed only if you enable ale_claw web_search tool

# Optional explicit overrides for claude_code routing
# export ANTHROPIC_BASE_URL=https://openrouter.ai/api
# export ANTHROPIC_AUTH_TOKEN=$OPENROUTER_API_KEY


# ---------- GCS task-data staging ----------
# The framework rsyncs input/software/eval from this bucket onto the VM
# before the agent runs, and reference/ just before evaluate (the latter
# is invisible to the agent during solve — formal benchmark visibility rule).
# Only matters for tasks with REQUIRES_TASK_DATA=True (most real tasks).

# Path to a Google service-account JSON file on YOUR machine. Framework
# uploads it to the VM at runtime + activates `gcloud auth activate-service-account`
# so VM-side gsutil can read from the bucket. Without this, VMs must rely on
# their default-attached service account having `roles/storage.objectViewer`.
export ALE_GCS_SA_KEY_PATH=$HOME/.config/agenthle/sa-key.json

# Bucket conventions (defaults shown). Override only if you have your own copy.
# export ALE_GCS_TASK_DATA_BUCKET=gs://agenthle
# export ALE_GCS_RESULTS_BUCKET=gs://agenthle-run-results


# ---------- Artifact mirror (origin_log + output pull) ----------
# Optional GCS bridge for faster artifact mirroring (VM → GCS → host). When
# unset, the framework falls back to direct cua-server file reads (slow but
# always works). Recommended for large transcripts / multi-GB outputs.

# export ALE_ARTIFACT_GCS_BUCKET=agenthle-artifacts
# export ALE_ARTIFACT_GCS_KEY_FILE=$HOME/.config/agenthle/artifact-sa.json
# export ALE_ARTIFACT_GCS_VM_KEY_FILE=/etc/ale/artifact-sa.json   # pre-staged on VM image


# ---------- ale_claw harness tunables (rarely needed) ----------
# export CONTEXT_WINDOW_OVERRIDE=200000


# ---------- Misc ----------
# export AGENTHLE_CREDENTIALS_DIR=$HOME/.config/agenthle/credentials  # for tasks declaring requiredCredentials
